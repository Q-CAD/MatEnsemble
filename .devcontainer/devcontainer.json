{
  "name": "MatEnsemble v0.2.1",
  "dockerFile": "Dockerfile",
  "context": "../",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",

        "python.defaultInterpreterPath": "/opt/basic/bin/python",
        "python.autoComplete.extraPaths": [
          "/opt/basic/lib/python3.12",
          "/opt/basic/lib/python3.12/site-packages",
          "/opt/flux-core/src/bindings/python"
        ],
        "python.analysis.extraPaths": [
          "/opt/basic/lib/python3.12/site-packages",
          "/opt/flux-core/src/bindings/python"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "GitHub.vscode-pull-request-github"
      ]
    }
  },

  "postStartCommand": "git config --global --add safe.directory /opt/matensemble"
}